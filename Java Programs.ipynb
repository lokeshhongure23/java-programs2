   "source": [
    "### 1.Write a Java program to display all the alphabets between ‘A’ to *Z” after every 2 seconds."
   ]
  },
  {
   "cell_type": "raw",
   "id": "9f7ea4b4-fe33-405e-a296-d6d539894749",
   "metadata": {},
   "source": [
    "public class Slip1 extends Thread \n",
    "{ \n",
    "char c; \n",
    "public void run() \n",
    "{ \n",
    "for(c ='A’; c<=’Z’;c++) \n",
    "{ \n",
    "System.out.println(\"\"+c); \n",
    "try{ \n",
    "Thread.sleep(2000); \n",
    "catch(Exception e) \n",
    "{ \n",
    "e.printStackTrace(); \n",
    "}  }  }  \n",
    "public static void main(String args[]) \n",
    "{ \n",
    "Slip1 t= new Slip1(); \n",
    "t.start(); \n",
    "} } "
   ]
  },
